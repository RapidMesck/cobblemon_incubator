{
  "schemaVersion": 1,
  "id": "cobblemon_incubator",
  "version": "${version}",
  "name": "Cobblemon Incubator",
  "description": "A Cobblemon and Cobbreeding addon that adds a customizable Egg Incubator with faster hatching, advanced filters, PC delivery, and Pasture automation.",
  "authors": ["RapidMesck"],
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "com.nbp.cobblemon_incubator.fabric.CobblemonIncubatorFabric"
      }
    ],
    "client": [
      {
        "adapter": "kotlin",
        "value": "com.nbp.cobblemon_incubator.fabric.CobblemonIncubatorFabricClient"
      }
    ]
  },
  "depends": {
    "fabricloader": ">=0.17.0",
    "minecraft": "1.21.1",
    "fabric-language-kotlin": "*",
    "cobblemon": "*",
    "cobbreeding": "*",
    "architectury": "*"
  }
}
